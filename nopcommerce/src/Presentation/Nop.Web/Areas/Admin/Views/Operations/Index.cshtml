@using Nop.Web.Areas.Admin.Models.Operations
@model OperationsDashboardModel
@{
    ViewBag.Title = "VerdeMart Operations Dashboard";
}

<div class="content-header clearfix">
    <h1 class="float-left">
        <i class="fas fa-tachometer-alt"></i>
        VerdeMart Operations Dashboard
    </h1>
    <div class="float-right">
        <button type="button" id="refresh-dashboard" class="btn btn-primary">
            <i class="fas fa-sync-alt"></i> Refresh
        </button>
    </div>
</div>

<div class="content">
    <div class="row">
        <!-- Panel 1: Stale Stock -->
        <div class="col-md-4">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-boxes"></i> Stale Stock
                    </h3>
                    <span class="badge badge-warning float-right">@Model.StaleStockRows.Count stale</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.StaleStockRows.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Stock</th>
                                        <th>Last Updated</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in Model.StaleStockRows.Take(10))
                                    {
                                        <tr>
                                            <td>@entry.ProductName</td>
                                            <td>@entry.AvailableQuantity</td>
                                            <td><span title="@entry.LastUpdatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC">
                                                @entry.LastUpdatedAgo
                                            </span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (Model.StaleStockRows.Count > 10)
                        {
                            <div class="text-center p-2">
                                <small>+ @(Model.StaleStockRows.Count - 10) more</small>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center p-4 text-muted">
                            <i class="fas fa-check-circle fa-2x mb-2 d-block"></i>
                            No stale stock entries
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Panel 2: Outbox Depth -->
        <div class="col-md-4">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-envelope"></i> Outbox Queue
                    </h3>
                    @if (Model.OutboxAlertActive)
                    {
                        <span class="badge badge-danger float-right">⚠ Alert: >5 min backlog</span>
                    }
                    else
                    {
                        <span class="badge badge-info float-right">@Model.TotalPendingOutbox pending</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (Model.OutboxDepthRows.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Event Type</th>
                                        <th>Count</th>
                                        <th>Oldest</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in Model.OutboxDepthRows)
                                    {
                                        <tr class="@(group.IsAlert ? "table-warning" : "")">
                                            <td>@group.EventType</td>
                                            <td>@group.PendingCount</td>
                                            <td>
                                                @if (group.IsAlert)
                                                {
                                                    <span class="text-danger">
                                                        @((DateTime.UtcNow - group.OldestPendingUtc).TotalMinutes.ToString("F1")) min
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span>@((DateTime.UtcNow - group.OldestPendingUtc).TotalMinutes.ToString("F1")) min</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-4 text-muted">
                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                            No pending outbox messages
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Panel 3: Circuit Breaker -->
        <div class="col-md-4">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-microchip"></i> Carrier Circuit Breaker
                    </h3>
                </div>
                <div class="card-body text-center">
                    <div class="circuit-state state-@Model.CircuitState.ToLower()">
                        <i class="fas fa-@(Model.CircuitState == "Closed" ? "check-circle" : Model.CircuitState == "Open" ? "exclamation-triangle" : "hourglass-half") fa-4x mb-2 d-block" 
                           style="color: @(Model.CircuitState == "Closed" ? "green" : Model.CircuitState == "Open" ? "red" : "orange")"></i>
                        <h4>@Model.CircuitState</h4>
                        <p class="text-muted">
                            Changed @(Model.CircuitSecondsInState / 60) min @(Model.CircuitSecondsInState % 60) sec ago
                        </p>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted">
                            @(Model.CircuitState == "Closed" 
                                ? "✓ Live carrier rates are being used" 
                                : Model.CircuitState == "Open"
                                    ? "⚠ Carrier is degraded — using fallback rates"
                                    : "⟳ Probing carrier for recovery")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-3">
        <div class="col-12 text-right">
            <small class="text-muted">
                Last refresh: @DateTime.UtcNow.ToString("HH:mm:ss") UTC
            </small>
        </div>
    </div>
</div>

<style>
    .circuit-state {
        padding: 20px;
        border-radius: 8px;
        transition: all 0.3s ease;
    }
    .circuit-state.state-closed {
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
    }
    .circuit-state.state-open {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
    }
    .circuit-state.state-halfopen {
        background-color: #fff3cd;
        border: 1px solid #ffeeba;
    }
    .card-title i {
        margin-right: 8px;
    }
    .table-warning {
        background-color: #fff3cd;
    }
</style>

<script>
    $(document).ready(function() {
        $('#refresh-dashboard').on('click', function() {
            location.reload();
        });
        
        // Auto-refresh every 30 seconds
        setInterval(function() {
            $('#refresh-dashboard').click();
        }, 30000);
    });
</script>
